@model ForgeTwin.Models.MaintenanceRecord
@{ ViewData["Title"] = "Delete maintenance record"; }
<h1>Delete maintenance record</h1><p class="text-danger">Are you sure you want to delete this record for <strong>@Model.Machine.Name</strong>?</p>
<dl class="row"><dt class="col-sm-3">Scheduled date</dt><dd class="col-sm-9">@Model.ScheduledDate</dd><dt class="col-sm-3">Type</dt><dd class="col-sm-9">@Model.Type</dd></dl>
<form asp-action="Delete"><input type="hidden" asp-for="Id" /><button type="submit" class="btn btn-danger">Delete</button> <a asp-action="Index" class="btn btn-secondary">Cancel</a></form>
