@model ForgeTwin.Models.WorkOrderInventoryItem
@{ ViewData["Title"] = "Remove work order part"; }
<h1>Remove work order part</h1><p>Remove <strong>@Model.InventoryItem.Name</strong> from work order #@Model.WorkOrderId?</p><form asp-action="Delete"><input type="hidden" asp-for="WorkOrderId" /><input type="hidden" asp-for="InventoryItemId" /><button type="submit" class="btn btn-danger">Remove</button> <a asp-action="Index" asp-route-workOrderId="@Model.WorkOrderId" class="btn btn-secondary">Cancel</a></form>
