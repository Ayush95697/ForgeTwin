@model ForgeTwin.Models.WorkOrderInventoryItem
@{ ViewData["Title"] = "Add work order part"; }
<h1>Add work order part</h1><form asp-action="Create"><div asp-validation-summary="ModelOnly" class="text-danger"></div><div class="mb-3"><label asp-for="WorkOrderId" class="form-label">Work order</label><select asp-for="WorkOrderId" class="form-select" asp-items="ViewBag.WorkOrderId"></select></div><div class="mb-3"><label asp-for="InventoryItemId" class="form-label">Inventory item</label><select asp-for="InventoryItemId" class="form-select" asp-items="ViewBag.InventoryItemId"></select></div><div class="mb-3"><label asp-for="QuantityUsed" class="form-label"></label><input asp-for="QuantityUsed" class="form-control" /><span asp-validation-for="QuantityUsed" class="text-danger"></span></div><button type="submit" class="btn btn-primary">Add</button> <a asp-action="Index" asp-route-workOrderId="@Model.WorkOrderId" class="btn btn-secondary">Cancel</a></form>
@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
