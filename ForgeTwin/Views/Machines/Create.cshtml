@model ForgeTwin.Models.Machine

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>Machine</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="Name" class="control-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Type" class="control-label"></label>
                <select asp-for="Type" class="form-control" asp-items="Html.GetEnumSelectList<MachineType>()"></select>
            </div>
            

            <div class="form-group">
                <label asp-for="Status" class="control-label"></label>
                <select asp-for="Status" class="form-control" asp-items="Html.GetEnumSelectList<MachineStatus>()"></select>
            </div>

            <div class="form-group">
                <label asp-for="InstalledOn" class="control-label"></label>
                <input asp-for="InstalledOn" class="form-control" />
                <span asp-validation-for="InstalledOn" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="MaintenanceRecords" class="control-label"></label>
                <input asp-for="MaintenanceRecords" class="form-control" />
                <span asp-validation-for="MaintenanceRecords" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="ProductionLogs" class="control-label"></label>
                <input asp-for="ProductionLogs" class="form-control" />
                <span asp-validation-for="ProductionLogs" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="WorkOrders" class="control-label"></label>
                <input asp-for="WorkOrders" class="form-control" />
                <span asp-validation-for="WorkOrders" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>
