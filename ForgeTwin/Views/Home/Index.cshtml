@model ForgeTwin.Models.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="container mt-4">
    <div class="row g-3">
        <!-- Machine Status Card -->
        <div class="col-md-4 mb-3">
            <div class="dashboard-card border-primary">
                <div class="icon-bg"><i class="bi bi-gear"></i></div>
                <div class="p-3">
                    <h5 class="card-title">Machine Status</h5>
                    <canvas id="machineStatusChart" height="200"></canvas>
                </div>
            </div>
        </div>

        <!-- Open Work Orders Card -->
        <div class="col-md-4 mb-3">
            <div class="dashboard-card border-success">
                <div class="icon-bg"><i class="bi bi-clipboard-check"></i></div>
                <div class="p-3">
                    <h5 class="card-title">Open Work Orders (by Priority)</h5>
                    <canvas id="workOrdersChart" height="200"></canvas>
                </div>
            </div>
        </div>

        <!-- Upcoming Maintenance Card -->
        <div class="col-md-4 mb-3">
            <div class="dashboard-card border-warning">
                <div class="icon-bg"><i class="bi bi-tools"></i></div>
                <div class="p-3">
                    <h5 class="card-title">Upcoming Maintenance</h5>
                    @if (Model.OpenWorkOrderPriorityCounts.Any())
                    {
                        <ul class="list-unstyled mb-0">
                            @foreach (var kvp in Model.OpenWorkOrderPriorityCounts)
                            {
                                <li>@kvp.Key: @kvp.Value</li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="mb-0">No upcoming maintenance.</p>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mt-3">
        <!-- Production Summary Card -->
        <div class="col-md-6 mb-3">
            <div class="dashboard-card border-info">
                <div class="icon-bg"><i class="bi bi-graph-up"></i></div>
                <div class="p-3">
                    <h5 class="card-title">Production (last 7 days)</h5>
                    <p>Total Units Produced: @Model.TotalUnitsProducedLast7Days</p>
                    <p>Total Defects: @Model.TotalDefectCountLast7Days</p>
                </div>
            </div>
        </div>

        <!-- Low Stock Items Card -->
        <div class="col-md-6 mb-3">
            <div class="dashboard-card border-danger">
                <div class="icon-bg"><i class="bi bi-exclamation-triangle"></i></div>
                <div class="p-3">
                    <h5 class="card-title">Low Stock Alerts</h5>
                    @if (Model.LowStockItems.Any())
                    {
                        <table class="table table-sm table-striped mb-0">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Qty</th>
                                    <th>Reorder</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.LowStockItems)
                                {
                                    <tr>
                                        <td>@item.Name</td>
                                        <td>@item.QuantityOnHand</td>
                                        <td>@item.ReorderThreshold</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="mb-0">All inventory levels are healthy.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mt-3">
    <div class="col-12 mb-3">
        <div class="dashboard-card border-primary">
            <div class="p-3">
                <h5 class="card-title">Production Trend (Last 7 Days)</h5>
                <canvas id="productionTrendChart" height="200"></canvas>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const machineStatusData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MachineStatusCounts));
    const workOrderData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.OpenWorkOrderPriorityCounts));
    const dailyTrendData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DailyProductionTrend));

    // Machine Status Doughnut
    const ctxMachine = document.getElementById('machineStatusChart').getContext('2d');
    new Chart(ctxMachine, {
        type: 'doughnut',
        data: {
            labels: Object.keys(machineStatusData),
            datasets: [{
                data: Object.values(machineStatusData),
                backgroundColor: ['#4e73df','#1cc88a','#36b9cc','#ff6384','#ffcd56']
            }]
        },
        options: { responsive: true }
    });

    // Work Orders Bar
    const ctxWork = document.getElementById('workOrdersChart').getContext('2d');
    new Chart(ctxWork, {
        type: 'bar',
        data: {
            labels: Object.keys(workOrderData),
            datasets: [{
                label: 'Open Work Orders',
                data: Object.values(workOrderData),
                backgroundColor: '#36b9cc'
            }]
        },
        options: {
            responsive: true,
            scales: { y: { beginAtZero: true } }
        }
    });

    // Production Trend Line
    const ctxTrend = document.getElementById('productionTrendChart').getContext('2d');
    const trendLabels = dailyTrendData.map(d => new Date(d.Date).toLocaleDateString());
    const unitsData = dailyTrendData.map(d => d.UnitsProduced);
    const defectData = dailyTrendData.map(d => d.DefectCount);
    new Chart(ctxTrend, {
        type: 'line',
        data: {
            labels: trendLabels,
            datasets: [
                {
                    label: 'Units Produced',
                    data: unitsData,
                    borderColor: '#4e73df',
                    fill: false,
                    tension: 0.1
                },
                {
                    label: 'Defects',
                    data: defectData,
                    borderColor: '#e74a3b',
                    fill: false,
                    tension: 0.1
                }
            ]
        },
        options: { responsive: true }
    });
</script>
}
