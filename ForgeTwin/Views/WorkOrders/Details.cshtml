@model ForgeTwin.Models.WorkOrder
@{ ViewData["Title"] = "Work order"; }
<h1>Work order</h1><dl class="row"><dt class="col-sm-3">Machine</dt><dd class="col-sm-9">@Model.Machine.Name</dd><dt class="col-sm-3">Assigned to</dt><dd class="col-sm-9">@Model.AssignedToUser?.Username</dd><dt class="col-sm-3">Status</dt><dd class="col-sm-9">@Model.Status</dd><dt class="col-sm-3">Priority</dt><dd class="col-sm-9">@Model.Priority</dd><dt class="col-sm-3">Due date</dt><dd class="col-sm-9">@Model.DueDate</dd></dl>
<h2 class="h4">Parts used</h2><p><a asp-controller="WorkOrderInventoryItems" asp-action="Index" asp-route-workOrderId="@Model.Id">Manage parts</a></p><table class="table"><thead><tr><th>Item</th><th>Quantity used</th></tr></thead><tbody>@foreach (var part in Model.WorkOrderInventoryItems) { <tr><td>@part.InventoryItem.Name</td><td>@part.QuantityUsed</td></tr> }</tbody></table><a asp-action="Edit" asp-route-id="@Model.Id">Edit</a> | <a asp-action="Index">Back to list</a>
