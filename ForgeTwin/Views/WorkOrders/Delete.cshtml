@model ForgeTwin.Models.WorkOrder
@{ ViewData["Title"] = "Delete work order"; }
<h1>Delete work order</h1><p class="text-danger">Are you sure you want to delete this work order for <strong>@Model.Machine.Name</strong>?</p><form asp-action="Delete"><input type="hidden" asp-for="Id" /><button type="submit" class="btn btn-danger">Delete</button> <a asp-action="Index" class="btn btn-secondary">Cancel</a></form>
